#!/usr/bin/env python3
"""Run the project-local APG skill projection command."""

from pathlib import Path
import runpy
import sys


command = Path(__file__).resolve(strict=True)
apg_root = command.parent.parent
helper_directory = apg_root / "libexec"
if command.parent.name != "bin" or not helper_directory.is_dir():
    print(
        "apg-project-skills: installed APG command layout is invalid; "
        "restore the APG checkout",
        file=sys.stderr,
    )
    raise SystemExit(1)

sys.path.insert(0, str(helper_directory))
runpy.run_module("apg_project_skills_commands", run_name="__main__")
