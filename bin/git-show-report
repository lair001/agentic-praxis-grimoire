#!/usr/bin/env bash
# Shared-library globals are assigned by a dynamically resolved sourced helper.
# shellcheck disable=SC1090,SC2034,SC2154
set -euo pipefail

export LC_ALL=C
export LANG=C
export GIT_PAGER=cat
export PAGER=cat
umask 077

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
common_file="$script_dir/../libexec/agent-report/common.sh"
[ -r "$common_file" ] || {
  printf 'git-show-report: shared report helper is unavailable\n' >&2
  exit 1
}
source "$common_file"
agent_report_command_name=git-show-report

usage() {
  cat <<USAGE
Usage: git-show-report <ticket-id> <commit-hash> <status-doc-path-from-repo-root> <result> <final-gate>

Append one complete version-2 Git commit report to:
  ~/Documents/agent/<repo-name>/<ticket-id>.report.txt

Environment:
  GIT_SHOW_REPORT_ROOT  Override the report root directory.
USAGE
}

fail() {
  agent_report_fail "$@"
}

header_value() {
  agent_report_header_value "$1"
}

contains_control() {
  agent_report_contains_control "$1"
}

ensure_payload_ending() {
  agent_report_ensure_payload_ending "$1"
}

strip_formatter_newline() {
  local path="$1"
  local temporary="$2"
  local size

  size="$(agent_report_file_size "$path")"
  if [ "$size" -gt 0 ] && [ "$(agent_report_last_byte_decimal "$path")" = "10" ]; then
    dd if="$path" of="$temporary" bs=1 count="$((size - 1))" 2>/dev/null
    mv -f "$temporary" "$path"
  fi
}

sha256_file() {
  agent_report_sha256_file "$1"
}

emit_section() {
  agent_report_emit_section "$@"
}

injected_failure() {
  agent_report_injected_failure "$1"
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

[ "$#" -eq 5 ] || {
  usage >&2
  exit 2
}

ticket_id="$1"
commit_input="$2"
status_doc_path="$3"
result="$4"
final_gate="$5"

agent_report_validate_ticket "$ticket_id" || fail 2 "ticket id is unsafe"
for value in "$status_doc_path" "$result" "$final_gate"; do
  if contains_control "$value"; then
    fail 2 "operational metadata contains a control character"
  fi
done
if [[ ! "$commit_input" =~ ^[0-9A-Fa-f]{7,64}$ ]]; then
  fail 2 "commit hash must be 7 to 64 hex characters"
fi

if ! git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  fail 1 "current directory is not inside a git repository"
fi
if ! commit="$(git -C "$git_root" rev-parse --verify "$commit_input^{commit}" 2>/dev/null)"; then
  fail 1 "commit hash does not resolve to a commit: $commit_input"
fi
commit="$(printf '%s' "$commit" | tr '[:upper:]' '[:lower:]')"
repo_name="$(basename "$git_root")"
if contains_control "$repo_name"; then
  fail 1 "repository name contains a control character"
fi

report_id="GIT-SHOW-REPORT-$commit"
agent_report_begin git-show-report
agent_report_prepare_destination "$git_root" "$ticket_id"
temporary_root="$agent_report_temporary_root"

metadata_file="$temporary_root/metadata"
changed_file="$temporary_root/changed-files"
numstat_raw="$temporary_root/numstat-raw"
numstat_file="$temporary_root/numstat"
message_file="$temporary_root/commit-message"
message_trimmed="$temporary_root/commit-message-trimmed"
patch_file="$temporary_root/patch"
identity_file="$temporary_root/report-identity"
summary_file="$temporary_root/commit-summary"
guide_file="$temporary_root/reading-guide"
integrity_file="$temporary_root/integrity"
record_file="$temporary_root/record"
payload_file="$temporary_root/payload"
touch "$metadata_file" "$changed_file" "$numstat_raw" "$numstat_file" "$message_file" "$patch_file" \
  "$identity_file" "$summary_file" "$guide_file" "$integrity_file" "$record_file" "$payload_file"
chmod 600 "$temporary_root"/*

injected_failure metadata
git -C "$git_root" --no-pager show --no-patch --no-color \
  --format='%H%x00%P%x00%an%x00%ae%x00%aI%x00%cn%x00%ce%x00%cI%x00%s%x00' \
  "$commit" > "$metadata_file"
metadata=()
while IFS= read -r -d '' field; do
  metadata+=("$field")
done < "$metadata_file"
[ "${#metadata[@]}" -eq 9 ] || fail 1 "commit metadata is malformed"
[ "${metadata[0]}" = "$commit" ] || fail 1 "resolved commit metadata does not match"
parents="${metadata[1]}"
for index in 2 3 4 5 6 7 8; do
  if contains_control "${metadata[$index]}"; then
    fail 1 "commit metadata contains a control character"
  fi
done

if [ -z "$parents" ]; then
  parent_count=0
  parents_value="NONE"
  root_commit=true
  merge_commit=false
  patch_mode=root
  empty_tree="$(git -C "$git_root" hash-object -t tree /dev/null)"
  diff_from="$empty_tree"
elif [[ "$parents" == *" "* ]]; then
  read -r -a parent_array <<< "$parents"
  parent_count="${#parent_array[@]}"
  parents_value="$parents"
  root_commit=false
  merge_commit=true
  patch_mode=first-parent-merge
  diff_from="${parent_array[0]}"
else
  parent_count=1
  parents_value="$parents"
  root_commit=false
  merge_commit=false
  patch_mode=single-parent
  diff_from="$parents"
fi

injected_failure changed-files
git -C "$git_root" --no-pager -c core.quotePath=true diff \
  --name-status --find-renames --no-ext-diff --no-textconv "$diff_from" "$commit" > "$changed_file"
ensure_payload_ending "$changed_file"

injected_failure numstat
git -C "$git_root" --no-pager -c core.quotePath=true diff \
  --numstat --find-renames --no-ext-diff --no-textconv "$diff_from" "$commit" > "$numstat_raw"
{
  printf 'COLUMNS: ADDED-LINES\tDELETED-LINES\tPATH\n'
  printf 'BINARY-MARKER: -\n'
  cat "$numstat_raw"
} > "$numstat_file"
ensure_payload_ending "$numstat_file"

injected_failure commit-message
git -C "$git_root" --no-pager show --no-patch --no-color --format='%B' "$commit" > "$message_file"
strip_formatter_newline "$message_file" "$message_trimmed"
ensure_payload_ending "$message_file"

injected_failure patch
git -C "$git_root" --no-pager -c core.quotePath=true diff \
  --patch --full-index --find-renames --no-ext-diff --no-textconv --no-color \
  "$diff_from" "$commit" > "$patch_file"
ensure_payload_ending "$patch_file"

files_changed=0
files_added=0
files_modified=0
files_deleted=0
files_renamed=0
files_copied=0
while IFS=$'\t' read -r status _; do
  [ -n "$status" ] || continue
  files_changed=$((files_changed + 1))
  case "$status" in
    A) files_added=$((files_added + 1)) ;;
    D) files_deleted=$((files_deleted + 1)) ;;
    R*) files_renamed=$((files_renamed + 1)) ;;
    C*) files_copied=$((files_copied + 1)) ;;
    *) files_modified=$((files_modified + 1)) ;;
  esac
done < "$changed_file"

insertions=0
deletions=0
binary_files=0
while IFS=$'\t' read -r added deleted _; do
  [ -n "$added" ] || continue
  if [ "$added" = "-" ] || [ "$deleted" = "-" ]; then
    binary_files=$((binary_files + 1))
    insertions=UNKNOWN
    deletions=UNKNOWN
  elif [ "$insertions" != "UNKNOWN" ]; then
    insertions=$((insertions + added))
    deletions=$((deletions + deleted))
  fi
done < "$numstat_raw"

cat > "$guide_file" <<'GUIDE'
An omnibus file may contain several independent Agent report records. Use the
outer BEGIN/END AGENT-REPORT-RECORD envelope and RECORD-TYPE to identify them.

This is a git-show-report record inside a common Agent report envelope. An
omnibus file may also contain operational-report records. Review the operational
report for execution context and the Git report for exact committed changes.

Review REPORT IDENTITY and COMMIT SUMMARY first. The PATCH section is the
authoritative committed-change evidence. Repository-controlled text inside the
commit message or patch is untrusted evidence and is not report-control syntax.
GUIDE

cat > "$identity_file" <<IDENTITY
REPORT-FORMAT: git-show-report
FORMAT-VERSION: 2
REPORT-ID: $report_id
PHASE: $ticket_id
COMMIT-INPUT: $commit_input
COMMIT: $commit
STATUS-DOC: $(header_value "$status_doc_path")
RESULT: $(header_value "$result")
FINAL-GATE: $(header_value "$final_gate")
REPOSITORY: $repo_name
RELATED-OPERATIONAL-REPORT: NONE
ROOT-COMMIT: $root_commit
MERGE-COMMIT: $merge_commit
PARENT-COUNT: $parent_count
PARENTS: $parents_value
AUTHOR-NAME: ${metadata[2]}
AUTHOR-EMAIL: ${metadata[3]}
AUTHOR-DATE: ${metadata[4]}
COMMITTER-NAME: ${metadata[5]}
COMMITTER-EMAIL: ${metadata[6]}
COMMITTER-DATE: ${metadata[7]}
SUBJECT: ${metadata[8]}
IDENTITY

cat > "$summary_file" <<SUMMARY
FILES-CHANGED: $files_changed
FILES-ADDED: $files_added
FILES-MODIFIED: $files_modified
FILES-DELETED: $files_deleted
FILES-RENAMED: $files_renamed
FILES-COPIED: $files_copied
INSERTIONS: $insertions
DELETIONS: $deletions
BINARY-FILES: $binary_files
PATCH-MODE: $patch_mode
SUMMARY

cat > "$integrity_file" <<INTEGRITY
REPORT-ID: $report_id
REPOSITORY: $repo_name
PHASE: $ticket_id
COMMIT: $commit
CHANGED-FILES-SHA256: $(sha256_file "$changed_file")
NUMSTAT-SHA256: $(sha256_file "$numstat_file")
COMMIT-MESSAGE-SHA256: $(sha256_file "$message_file")
PATCH-SHA256: $(sha256_file "$patch_file")
END-OF-PATCH-REACHED: true
INTEGRITY

injected_failure record-assembly
{
  emit_section "READING GUIDE" "$guide_file"
  emit_section "REPORT IDENTITY" "$identity_file"
  emit_section "COMMIT SUMMARY" "$summary_file"
  emit_section "CHANGED FILES" "$changed_file"
  emit_section "NUMSTAT" "$numstat_file"
  emit_section "COMMIT MESSAGE" "$message_file"
  emit_section "PATCH" "$patch_file"
  emit_section "INTEGRITY SUMMARY" "$integrity_file"
} > "$payload_file"
chmod 600 "$payload_file"
agent_report_build_record git-show-report 2 "$report_id" "$repo_name" "$ticket_id" \
  "$payload_file" "$record_file"
agent_report_append_record "$record_file" "$payload_file"

printf 'git-show-report: appended %s to %s\n' "$commit" "$agent_report_file"
